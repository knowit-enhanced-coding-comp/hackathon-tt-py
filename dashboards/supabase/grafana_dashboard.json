{
  "__inputs": [
    {
      "name": "DS_SUPABASE",
      "label": "Supabase PostgreSQL",
      "description": "Your Supabase project PostgreSQL connection",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "AI Hackathon Leaderboard — best submission per team",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "🏆 Leaderboard",
      "type": "table",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Rank", "desc": false }],
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "overall" },
            "properties": [
              { "id": "displayName", "value": "Overall Score" },
              { "id": "unit", "value": "none" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 50 },
                    { "color": "yellow", "value": 65 },
                    { "color": "green", "value": 80 }
                  ]
              }}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rank" },
            "properties": [
              { "id": "displayName", "value": "Rank" },
              { "id": "custom.width", "value": 60 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "team" },
            "properties": [{ "id": "displayName", "value": "Team" }]
          },
          {
            "matcher": { "id": "byName", "options": "project" },
            "properties": [{ "id": "displayName", "value": "Project" }]
          },
          {
            "matcher": { "id": "byName", "options": "tests_pct" },
            "properties": [
              { "id": "displayName", "value": "Tests %" },
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "quality_pct" },
            "properties": [
              { "id": "displayName", "value": "Quality %" },
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "quality_weighted_grade" },
            "properties": [{ "id": "displayName", "value": "Grade" }]
          },
          {
            "matcher": { "id": "byName", "options": "submitted_at" },
            "properties": [
              { "id": "displayName", "value": "Last Submitted" },
              { "id": "unit", "value": "dateTimeAsLocal" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "legal" },
            "properties": [{ "id": "displayName", "value": "Legal" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
          "rawSql": "SELECT rank, team, project, overall, tests_pct, quality_pct, quality_weighted_grade, legal, submitted_at FROM leaderboard WHERE ($project = 'All' OR project = $project) ORDER BY rank ASC, team ASC;",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Overall Score by Team",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 14 },
      "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "yellow", "value": 65 },
              { "color": "green", "value": 80 }
            ]
          },
          "custom": { "fillOpacity": 80 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
          "rawSql": "SELECT team, overall FROM leaderboard WHERE ($project = 'All' OR project = $project) ORDER BY overall DESC;",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Sub-scores — Best Submission per Team",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 14 },
      "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -30,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 1 }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
          "rawSql": "SELECT team, translated_complexity_score, translated_dead_code_score, translated_duplication_score, translated_coupling_score, translated_dependency_score, translated_architecture_score FROM leaderboard WHERE ($project = 'All' OR project = $project) ORDER BY overall DESC;",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Total Submissions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 24 },
      "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
          "rawSql": "SELECT COUNT(*) AS \"Total Submissions\" FROM submissions WHERE ($project = 'All' OR project = $project);",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Teams Competing",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 24 },
      "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
          "rawSql": "SELECT COUNT(DISTINCT team) AS \"Teams\" FROM submissions WHERE ($project = 'All' OR project = $project);",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "Top Score",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 24 },
      "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 50 }, { "color": "green", "value": 80 }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
          "rawSql": "SELECT MAX(overall) AS \"Top Score\" FROM leaderboard WHERE ($project = 'All' OR project = $project);",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "title": "Check Results by Team",
      "description": "OK / FAIL / SKIPPED per check. Dynamically shows all checks that have been submitted.",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "check_status" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "OK":      { "color": "green",  "text": "✅ OK" } } },
                { "type": "value", "options": { "FAIL":    { "color": "red",    "text": "❌ FAIL" } } },
                { "type": "value", "options": { "SKIPPED": { "color": "orange", "text": "⏭ SKIPPED" } } }
              ]},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
          "rawSql": "SELECT sc.team, sc.check_name, sc.check_status FROM submission_checks sc INNER JOIN leaderboard lb ON sc.submission_id = lb.id WHERE ($project = 'All' OR sc.project = $project) ORDER BY sc.team, sc.check_name;",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "title": "Submissions Over Time",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
      "options": {
        "orientation": "vertical",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
          "rawSql": "SELECT date_trunc('hour', submitted_at) AS time, team, COUNT(*) AS submissions FROM submissions WHERE ($project = 'All' OR project = $project) GROUP BY 1, 2 ORDER BY 1;",
          "format": "table",
          "refId": "A"
        }
      ]
    }

  ],

  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["hackathon", "leaderboard", "ai"],
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "${DS_SUPABASE}" },
        "query": "SELECT 'All' UNION SELECT DISTINCT project FROM submissions ORDER BY 1;",
        "current": { "text": "All", "value": "All" },
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AI Hackathon Leaderboard",
  "uid": "ai-hackathon-leaderboard",
  "version": 1
}
