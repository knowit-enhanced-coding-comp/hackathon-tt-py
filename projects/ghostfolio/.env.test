COMPOSE_PROJECT_NAME=ghostfolio-test

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=testredispassword

# POSTGRES
POSTGRES_DB=ghostfolio-test-db
